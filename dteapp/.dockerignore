# ─── Docker build context exclusions ───────────────────────
# These are NOT copied into the Docker image, keeping the
# image lean and preventing secrets from leaking in.

# Dependencies (will be installed fresh inside the image)
node_modules/

# Build output (generated inside the image)
dist/
dist-ssr/

# Environment files — NEVER bake .env secrets into the image
# Pass them as --build-arg or via docker-compose args instead
.env
.env.*
!.env.example

# Version control
.git/
.gitignore

# Editor / IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS temp files
Thumbs.db
